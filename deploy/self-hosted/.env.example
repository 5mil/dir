# =============================================================
# dir Self-Hosted — Environment Variables
# Copy to .env and fill in values (or run install.sh to auto-generate)
# =============================================================

DOMAIN=your-domain.com

DB_NAME=dir
DB_USER=dir
DB_PASSWORD=__DB_PASSWORD__

JWT_SECRET=__JWT_SECRET__
ENCRYPTION_KEY=__ENCRYPTION_KEY__
APP_ENV=production

WATCHTOWER_MONITOR_ONLY=false

BACKUP_DIR=/opt/dir/backups
BACKUP_RETAIN_DAYS=30
